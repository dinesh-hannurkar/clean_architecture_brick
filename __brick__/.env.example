# Environment Configuration Template
# Copy this file to .env and fill in actual values
# NEVER commit .env to version control

# ============================================
# API Configuration
# ============================================

# Development Environment
DEV_API_BASE_URL=https://api-dev.velocity.example.com
DEV_API_TIMEOUT=30000

# Staging Environment
STAGING_API_BASE_URL=https://api-staging.velocity.example.com
STAGING_API_TIMEOUT=30000

# Production Environment
PROD_API_BASE_URL=https://api.velocity.example.com
PROD_API_TIMEOUT=15000

# ============================================
# Firebase Configuration
# ============================================

# Firebase Project IDs
DEV_FIREBASE_PROJECT_ID=velocity-dev-xxxxx
STAGING_FIREBASE_PROJECT_ID=velocity-staging-xxxxx
PROD_FIREBASE_PROJECT_ID=velocity-prod-xxxxx

# Firebase Messaging
DEV_FCM_SENDER_ID=123456789012
STAGING_FCM_SENDER_ID=123456789012
PROD_FCM_SENDER_ID=123456789012

# ============================================
# OAuth Configuration
# ============================================

# Google Sign-In Client IDs
GOOGLE_CLIENT_ID_ANDROID=xxxxx-xxxxx.apps.googleusercontent.com
GOOGLE_CLIENT_ID_IOS=xxxxx-xxxxx.apps.googleusercontent.com

# ============================================
# Feature Flags
# ============================================

ENABLE_OFFLINE_MODE=true
ENABLE_ANALYTICS=false
ENABLE_CRASH_REPORTING=true
ENABLE_DEBUG_LOGGING=true

# ============================================
# Application Configuration
# ============================================

APP_NAME=Velocity
APP_VERSION=0.1.0
BUILD_NUMBER=1

# ============================================
# Logging Configuration
# ============================================

LOG_LEVEL_DEV=debug
LOG_LEVEL_STAGING=info
LOG_LEVEL_PROD=warning

# ============================================
# Razorpay Configuration
RAZORPAY_KEY_ID=rzp_test_your_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret

# Third-Party Services
SENTRY_DSN=https://xxxx@sentry.io/xxxx
GOOGLE_MAPS_API_KEY=AIzaSyxxxxxxxxxxxxxxxxxxxxxx

# Operational Support
SUPPORT_EMAIL=support@velexp.com
SUPPORT_PHONE=+919876543210
SUPPORT_WHATSAPP=https://wa.me/919876543210

# ============================================
# Security Configuration
# ============================================

# Session timeout (in minutes)
SESSION_TIMEOUT=30

# API rate limiting
MAX_API_REQUESTS_PER_MINUTE=60

# ============================================
# Development Tools
# ============================================

# Enable Flutter DevTools
ENABLE_DEVTOOLS=true

# Enable performance overlay
ENABLE_PERFORMANCE_OVERLAY=false
